rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users: readable by any authenticated user (for friend search),
    // writable only by the owner
    match /users/{uid} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == uid;
      allow update: if request.auth != null && (
        // Owner can update their own document
        request.auth.uid == uid ||
        // Anyone can add themselves to another user's friends array (friend acceptance),
        // as long as they're only changing the friends field and only adding their own uid
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['friends']) &&
         request.resource.data.friends.hasAll(resource.data.friends) &&
         request.resource.data.friends.removeAll(resource.data.friends).hasOnly([request.auth.uid])) ||
        // Anyone can remove themselves from another user's friends array (account deletion),
        // changing only the friends field and only removing their own uid
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['friends']) &&
         resource.data.friends.hasAll(request.resource.data.friends) &&
         resource.data.friends.removeAll(request.resource.data.friends).hasOnly([request.auth.uid]))
      );
      // Owner can delete their own account document
      allow delete: if request.auth != null && request.auth.uid == uid;
    }

    // Friend requests: sender or recipient can read/write
    match /friendRequests/{requestId} {
      allow read: if request.auth != null &&
        (resource.data.fromUid == request.auth.uid ||
         resource.data.toUid == request.auth.uid);
      allow create: if request.auth != null &&
        request.resource.data.fromUid == request.auth.uid;
      allow delete: if request.auth != null &&
        (resource.data.fromUid == request.auth.uid ||
         resource.data.toUid == request.auth.uid);
      allow update: if false;
    }

    // Check-ins: owner writes, friends can read
    // Document ID format: {uid}_{YYYY-MM-DD}
    match /checkins/{checkinId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null &&
        checkinId.matches(request.auth.uid + '_.*');
    }
  }
}
